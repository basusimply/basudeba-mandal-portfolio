# Public site URL for metadata (set to your Vercel URL or custom domain)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Google Analytics 4 Measurement ID (optional — omit to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend (contact form) — https://resend.com
# Create an API key and set your recipient inbox.
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=you@example.com
# Optional. Defaults to Resend onboarding sender for testing.
# For production, verify a domain in Resend and use e.g. Portfolio <hello@yourdomain.com>
RESEND_FROM=Portfolio <onboarding@resend.dev>
